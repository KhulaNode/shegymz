# Lightweight SheGymZ website environment

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PLAN_CODE=

# App URLs
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=https://portal.shegymz.com
PORTAL_URL=https://portal.shegymz.com

# Plan pricing
NEXT_PUBLIC_SUBSCRIPTION_AMOUNT=399

# Email (Plunk)
PLUNK_API_KEY=your_plunk_api_key_here
PLUNK_FROM_EMAIL=hello@yourdomain.com
ADMIN_EMAIL=your_admin_inbox@gmail.com
NEXT_PUBLIC_CONTACT_EMAIL=admin@shegymz.com
CONTACT_EMAIL=admin@shegymz.com
NODE_ENV=development

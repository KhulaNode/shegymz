# Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git!

# ────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ────────────────────────────────────────────────────────────────────────────
# Local dev (direct connection to your local Postgres or the Docker service):
#   postgresql://shegymz:your_password@localhost:5432/shegymzdb
# Docker Compose (container-to-container):
#   postgresql://shegymz:your_password@postgres:5432/shegymzdb
DATABASE_URL=postgresql://shegymz:your_password@localhost:5432/shegymzdb

# PostgreSQL credentials — used by docker-compose for the postgres service
POSTGRES_DB=shegymzdb
POSTGRES_USER=shegymz
POSTGRES_PASSWORD=your_password

# ────────────────────────────────────────────────────────────────────────────
# Metabase
# ────────────────────────────────────────────────────────────────────────────
# Host port for the Metabase UI (default: 3001 → http://localhost:3001)
METABASE_PORT=3001
# Internal password for Metabase’s own postgres instance (not the app DB)
METABASE_DB_PASSWORD=change_me_metabase_secret

# ────────────────────────────────────────────────────────────────────────────
# Yoco Online Payments
# ────────────────────────────────────────────────────────────────────────────
# Get your keys from https://dashboard.yoco.com/developers/api-keys
# Use sk_test_... for testing, sk_live_... for production.
YOCO_SECRET_KEY=sk_test_your_secret_key_here

# Webhook secret — copy from the Yoco Dashboard after creating a webhook endpoint.
# Set webhook URL to: https://yourdomain.com/api/webhook/yoco
# Subscribe to events: payment.succeeded, payment.failed, payment.cancelled
YOCO_WEBHOOK_SECRET=your_yoco_webhook_secret_here

# ────────────────────────────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────────────────────────────
# Base URL — used to build Yoco success/cancel redirect URLs.
# In production: https://shegymz.com   Locally: http://localhost:3000
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────────────────────
# Subscription / Plan pricing
# ────────────────────────────────────────────────────────────────────────────
# Monthly price in ZAR — single source of truth used by YocoProvider.
NEXT_PUBLIC_SUBSCRIPTION_AMOUNT=399

# ────────────────────────────────────────────────────────────────────────────
# Email (Plunk)
# ────────────────────────────────────────────────────────────────────────────
# Get your API key from https://useplunk.com/dashboard
PLUNK_API_KEY=your_plunk_api_key_here

# Admin email — receives all internal notifications (payments, subscriptions, etc.).
# This is PRIVATE and never shown to clients.
ADMIN_EMAIL=your_admin_inbox@gmail.com

# Contact email — shown publicly to clients in emails they receive and on the website.
NEXT_PUBLIC_CONTACT_EMAIL=admin@shegymz.com
CONTACT_EMAIL=admin@shegymz.com

# ────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
